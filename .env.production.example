# Production env template.
# Copy these keys into your hosting platform's environment variables.
# Do NOT commit a filled-in version of this file.

APP_NAME=Lollipops
APP_ENV=production
APP_KEY=                                  # generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-domain.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Database (MariaDB/MySQL) ----
DB_CONNECTION=mariadb
DB_HOST=                                  # internal hostname of the DB service
DB_PORT=3306
DB_DATABASE=lollipops
DB_USERNAME=lollipops
DB_PASSWORD=

# ---- Sessions / Cache / Queue ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ---- Filesystem (S3) ----
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Mail ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@lolipopslancashire.co.uk"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Site ----
SITE_FULLNAME="Penwortham Lollipops"
SITE_ADDRESS="Liverpool Road, Penwortham, Preston, PR1 0TB"
SITE_TELEPHONE="01772 378 415"
SITE_EMAIL="hello@lolipopslancashire.co.uk"
SITE_ESTABLISHED=2022
POSTS_SLUG_PREFIX=news-updates

# ---- Vite (build-time only) ----
VITE_APP_NAME="${APP_NAME}"

# ---- Trust reverse proxy (Coolify, Traefik, Caddy, etc.) ----
TRUSTED_PROXIES=*
