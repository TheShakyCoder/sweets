# Production env template for Coolify.
# Copy these keys into Coolify → Application → Environment Variables.
# Do NOT commit a filled-in version of this file.

APP_NAME=WACA
APP_ENV=production
APP_KEY=                                  # generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-domain.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Database (MariaDB/MySQL service in Coolify) ----
DB_CONNECTION=mariadb
DB_HOST=                                  # internal Coolify hostname of the DB service
DB_PORT=3306
DB_DATABASE=waca
DB_USERNAME=waca
DB_PASSWORD=

# ---- Sessions / Cache / Queue ----
# All three use the DB by default — simplest for a single-container deploy.
# Switch to redis if/when you add a Redis service in Coolify.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ---- Filesystem (S3) ----
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Mail ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Vite (build-time only — must be present during the Nixpacks build) ----
VITE_APP_NAME="${APP_NAME}"

# ---- Trust Coolify's reverse proxy so secure cookies / scheme detection work ----
TRUSTED_PROXIES=*
